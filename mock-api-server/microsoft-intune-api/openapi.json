    "/v1.0/deviceManagement/managedDevices/{managedDeviceId}/users": {
      "get": {
        "operationId": "getManagedDeviceUsers",
        "summary": "List users associated with a managed device",
        "description": "Returns the user(s) enrolled on this Intune-managed device. The user id equals Entra user.id and Entra device registeredUsers. Note: Groups in Intune are Entra security groups — use GET /v1.0/groups from the Entra ID API.",
        "tags": ["Managed Devices"],
        "parameters": [
          { "name": "managedDeviceId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" }, "example": "eeeeeeee-0001-0001-0001-000000000001" }
        ],
        "responses": {
          "200": {
            "description": "List of users associated with the managed device.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@odata.context": { "type": "string" },
                    "value": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id":                      { "type": "string", "format": "uuid", "description": "Entra user object ID — equals Entra user.id.", "example": "aaaaaaaa-0000-0001-0000-000000000001" },
                          "displayName":             { "type": "string", "example": "Alice Johnson" },
                          "userPrincipalName":       { "type": "string", "example": "alice.johnson@contoso.com" },
                          "mail":                    { "type": "string", "format": "email" },
                          "givenName":               { "type": "string" },
                          "surname":                 { "type": "string" },
                          "jobTitle":                { "type": "string" },
                          "department":              { "type": "string" },
                          "accountEnabled":          { "type": "boolean" },
                          "userType":                { "type": "string", "enum": ["Member", "Guest"] },
                          "onPremisesSamAccountName":{ "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": { "description": "Device not found." }
        }
      }
    }
