    "/v1.0/users/{id}/memberOf": {
      "get": {
        "operationId": "getUserMemberOf",
        "summary": "List groups and roles a user belongs to",
        "description": "Returns all groups and directory roles the user is a member of. Includes both security groups (on-prem synced and cloud-only) and Entra directory roles. Use this to understand a user's access scope.",
        "tags": ["Users"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "User object ID or userPrincipalName.", "example": "aaaaaaaa-0000-0001-0000-000000000001" },
          { "name": "$select", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OData list of groups and directory roles the user is a member of.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@odata.context": { "type": "string" },
                    "@odata.count": { "type": "integer" },
                    "value": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "@odata.type":   { "type": "string", "example": "#microsoft.graph.group" },
                          "id":            { "type": "string", "format": "uuid" },
                          "displayName":   { "type": "string" },
                          "description":   { "type": "string" },
                          "securityEnabled": { "type": "boolean" },
                          "groupTypes":    { "type": "array", "items": { "type": "string" } },
                          "roleTemplateId":{ "type": "string", "description": "Only present for directoryRole objects." }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": { "description": "User not found." }
        }
      }
    },
    "/v1.0/groups/{id}/members": {
      "get": {
        "operationId": "getGroupMembers",
        "summary": "List members of a group",
        "description": "Returns all members of the group — can include users, devices, service principals, and nested groups. Each member object includes @odata.type to distinguish member type.",
        "tags": ["Groups"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Group object ID.", "example": "cccccccc-0000-0001-0000-000000000001" },
          { "name": "$select", "in": "query", "schema": { "type": "string" } },
          { "name": "$top", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "OData list of group members (users and/or devices).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@odata.context": { "type": "string" },
                    "@odata.count": { "type": "integer" },
                    "value": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "@odata.type":          { "type": "string", "example": "#microsoft.graph.user" },
                          "id":                   { "type": "string", "format": "uuid" },
                          "displayName":          { "type": "string" },
                          "userPrincipalName":    { "type": "string", "description": "Present for user members." },
                          "deviceId":             { "type": "string", "description": "Present for device members — equals Intune azureADDeviceId and Defender aadDeviceId." },
                          "operatingSystem":      { "type": "string", "description": "Present for device members." },
                          "trustType":            { "type": "string", "description": "Present for device members." },
                          "isCompliant":          { "type": "boolean", "description": "Present for device members." }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "404": { "description": "Group not found." }
        }
      }
    },
    "/v1.0/devices/{id}/registeredUsers": {
      "get": {
        "operationId": "getDeviceRegisteredUsers",
        "summary": "List users registered to a device",
        "description": "Returns the users who registered this device in Entra ID. Typically one user (the employee who joined the laptop to Entra). The user id cross-references Intune managedDevice.userId.",
        "tags": ["Devices"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" }, "description": "Entra device directory object ID.", "example": "bbbbbbbb-0000-0001-0000-000000000001" }
        ],
        "responses": {
          "200": {
            "description": "OData list of users registered to the device.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "@odata.context": { "type": "string" },
                    "value": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/User" }
                    }
                  }
                }
              }
            }
          },
          "404": { "description": "Device not found." }
        }
      }
    }
  }
